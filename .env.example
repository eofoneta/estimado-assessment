# Copy to .env and fill in at least one key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Path to the downloaded dataset folder (auto-detected if left blank)
DATASET_ROOT=/path/to/AI Takeoff Builder Challenge - Assessment 1.0

# AI provider: anthropic | openai | openrouter
AI_PROVIDER=openrouter
ANTHROPIC_MODEL=claude-opus-4-5
OPENAI_MODEL=gpt-4o
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Cost controls
MAX_PAGES_PER_FILE=2
MAX_FILES_PER_PROJECT=5
